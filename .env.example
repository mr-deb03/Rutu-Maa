# ---- Rutu-Maa (Next.js) configuration ----
# Copy to ".env" and fill in. Everything is optional for LOCAL dev:
#   - No DATABASE_URL  -> uses embedded Postgres (PGlite) at ./data/pgdata
#   - No ANTHROPIC key -> Diet page uses the on-device engine
#   - No VAPID keys    -> push notifications stay off

# Postgres connection string. REQUIRED in production / on Vercel.
# Examples:
#   Neon:     postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#   Supabase: postgres://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Local:    postgres://postgres:postgres@localhost:5432/rutumaa
DATABASE_URL=

# AI dietary plans — any OpenAI-compatible provider. Set key + base URL + model.
# FREE (no card): Groq -> https://console.groq.com/keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
# FREE alt: Google Gemini -> https://aistudio.google.com/apikey
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  + OPENAI_MODEL=gemini-2.0-flash
# Paid: OpenAI -> OPENAI_BASE_URL=https://api.openai.com/v1  + OPENAI_MODEL=gpt-4o-mini

# Web Push (background notifications). Generate with: npm run genkeys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Same value as VAPID_PUBLIC_KEY, exposed to the browser to subscribe:
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Secret that protects the cron endpoint. Vercel sends it automatically as
# "Authorization: Bearer <CRON_SECRET>" when this env var is set.
CRON_SECRET=
